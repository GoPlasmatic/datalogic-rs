[
  "# Reduce operator tests",
  {
    "description": "Basic reduce - sum of numbers",
    "rule": {
      "reduce": [
        [1, 2, 3, 4, 5],
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        0
      ]
    },
    "data": null,
    "result": 15
  },
  {
    "description": "Reduce with array from variable",
    "rule": {
      "reduce": [
        { "var": "numbers" },
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        0
      ]
    },
    "data": { "numbers": [10, 20, 30] },
    "result": 60
  },
  {
    "description": "Reduce array of objects - sum simple property",
    "rule": {
      "reduce": [
        { "var": "items" },
        { "+": [{ "var": "accumulator" }, { "var": "current.value" }] },
        0
      ]
    },
    "data": {
      "items": [
        { "value": 100 },
        { "value": 200 },
        { "value": 300 }
      ]
    },
    "result": 600
  },
  {
    "description": "Reduce array of objects - sum nested property",
    "rule": {
      "reduce": [
        { "var": "items" },
        { "+": [{ "var": "accumulator" }, { "var": "current.details.amount" }] },
        0
      ]
    },
    "data": {
      "items": [
        { "details": { "amount": 100 } },
        { "details": { "amount": 200 } },
        { "details": { "amount": 300 } }
      ]
    },
    "result": 600
  },
  {
    "description": "Reduce with property name starting with number (not nested)",
    "rule": {
      "reduce": [
        { "var": "items" },
        { "+": [{ "var": "accumulator" }, { "var": "current.32B" }] },
        0
      ]
    },
    "data": {
      "items": [
        { "32B": 100 },
        { "32B": 200 },
        { "32B": 300 }
      ]
    },
    "result": 600
  },

  "# Bug reproduction - nested property with parent starting with number",
  {
    "description": "Reduce with nested property where parent starts with number",
    "rule": {
      "reduce": [
        { "var": "items" },
        { "+": [{ "var": "accumulator" }, { "var": "current.32B.amount" }] },
        0
      ]
    },
    "data": {
      "items": [
        { "32B": { "amount": 100 } },
        { "32B": { "amount": 200 } },
        { "32B": { "amount": 300 } }
      ]
    },
    "result": 600
  },
  {
    "description": "MT104 structure - reduce with fields.# and numeric property",
    "rule": {
      "reduce": [
        { "var": "fields.#" },
        { "+": [{ "var": "accumulator" }, { "var": "current.32B.amount" }] },
        0
      ]
    },
    "data": {
      "fields": {
        "#": [
          { "32B": { "amount": 100, "currency": "USD" } },
          { "32B": { "amount": 200, "currency": "USD" } },
          { "32B": { "amount": 100, "currency": "USD" } }
        ]
      }
    },
    "result": 400
  },

  "# Combination with other operators",
  {
    "description": "Reduce after map operation",
    "rule": {
      "reduce": [
        {
          "map": [
            { "var": "items" },
            { "var": "32B.amount" }
          ]
        },
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        0
      ]
    },
    "data": {
      "items": [
        { "32B": { "amount": 100 } },
        { "32B": { "amount": 200 } },
        { "32B": { "amount": 300 } }
      ]
    },
    "result": 600
  },

  "# Different accumulator operations",
  {
    "description": "Reduce with multiplication",
    "rule": {
      "reduce": [
        [1, 2, 3, 4],
        { "*": [{ "var": "accumulator" }, { "var": "current" }] },
        1
      ]
    },
    "data": null,
    "result": 24
  },
  {
    "description": "String concatenation with reduce",
    "rule": {
      "reduce": [
        ["Hello", " ", "World"],
        { "cat": [{ "var": "accumulator" }, { "var": "current" }] },
        ""
      ]
    },
    "data": null,
    "result": "Hello World"
  },

  "# Edge cases",
  {
    "description": "Reduce empty array returns initial value",
    "rule": {
      "reduce": [
        [],
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        42
      ]
    },
    "data": null,
    "result": 42
  },
  {
    "description": "Reduce single element array",
    "rule": {
      "reduce": [
        [5],
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        10
      ]
    },
    "data": null,
    "result": 15
  },
  {
    "description": "Reduce with null values in array",
    "rule": {
      "reduce": [
        [1, null, 2, null, 3],
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        0
      ]
    },
    "data": null,
    "result": 6
  },

  "# Complex MT104 validation scenario",
  {
    "description": "MT104 validation - sum of transaction amounts equals header amount",
    "rule": {
      "if": [
        { "exists": ["fields", "19"] },
        {
          "==": [
            { "var": "fields.19.amount" },
            {
              "reduce": [
                { "var": "fields.#" },
                { "+": [{ "var": "accumulator" }, { "var": "current.32B.amount" }] },
                0
              ]
            }
          ]
        },
        true
      ]
    },
    "data": {
      "fields": {
        "#": [
          {
            "32B": {
              "amount": 250.0,
              "currency": "GIP"
            }
          },
          {
            "32B": {
              "amount": 350.0,
              "currency": "GIP"
            }
          },
          {
            "32B": {
              "amount": 400.0,
              "currency": "GIP"
            }
          }
        ],
        "19": {
          "amount": 1000.0
        }
      }
    },
    "result": true
  },

  "# Subtraction operand order (fast-path regression: acc-LHS vs current-LHS)",
  {
    "description": "Subtract reduce - accumulator on LHS (integers)",
    "rule": {
      "reduce": [
        [10, 20, 30],
        { "-": [{ "var": "accumulator" }, { "var": "current" }] },
        100
      ]
    },
    "data": null,
    "result": 40
  },
  {
    "description": "Subtract reduce - current on LHS (integers)",
    "rule": {
      "reduce": [
        [10, 20, 30],
        { "-": [{ "var": "current" }, { "var": "accumulator" }] },
        0
      ]
    },
    "data": null,
    "result": 20
  },
  {
    "description": "Subtract reduce - accumulator on LHS (floats)",
    "rule": {
      "reduce": [
        [1.5, 2.25],
        { "-": [{ "var": "accumulator" }, { "var": "current" }] },
        10
      ]
    },
    "data": null,
    "result": 6.25
  },
  {
    "description": "Subtract reduce - current on LHS (floats)",
    "rule": {
      "reduce": [
        [1.5, 2.5],
        { "-": [{ "var": "current" }, { "var": "accumulator" }] },
        0.5
      ]
    },
    "data": null,
    "result": 1.5
  },
  {
    "description": "Subtract reduce - current on LHS, mixed ints and floats",
    "rule": {
      "reduce": [
        [5, 2.5],
        { "-": [{ "var": "current" }, { "var": "accumulator" }] },
        1
      ]
    },
    "data": null,
    "result": -1.5
  },
  {
    "description": "Subtract reduce - accumulator on LHS, i64 overflow promotes to float",
    "rule": {
      "reduce": [
        [1],
        { "-": [{ "var": "accumulator" }, { "var": "current" }] },
        -9223372036854775808
      ]
    },
    "data": null,
    "result": -9223372036854775808
  },
  {
    "description": "Subtract reduce - current on LHS, i64 overflow promotes to float",
    "rule": {
      "reduce": [
        [-9223372036854775808],
        { "-": [{ "var": "current" }, { "var": "accumulator" }] },
        1
      ]
    },
    "data": null,
    "result": -9223372036854775808
  },
  {
    "description": "Subtract reduce - current on LHS with property path",
    "rule": {
      "reduce": [
        { "var": "items" },
        { "-": [{ "var": "current.value" }, { "var": "accumulator" }] },
        0
      ]
    },
    "data": {
      "items": [{ "value": 10 }, { "value": 4 }]
    },
    "result": -6
  },
  {
    "description": "Subtract reduce - accumulator on LHS with nulls (general path)",
    "rule": {
      "reduce": [
        [10, null, 3],
        { "-": [{ "var": "accumulator" }, { "var": "current" }] },
        20
      ]
    },
    "data": null,
    "result": 7
  },
  {
    "description": "Subtract reduce - current on LHS with nulls (general path)",
    "rule": {
      "reduce": [
        [10, null, 3],
        { "-": [{ "var": "current" }, { "var": "accumulator" }] },
        0
      ]
    },
    "data": null,
    "result": 13
  },

  "# reduce(map(...)) fusion shapes - results must be identical fused or not",
  {
    "description": "Fused: sum of map with var*literal body (ints)",
    "rule": {
      "reduce": [
        { "map": [{ "var": "items" }, { "*": [{ "var": "" }, 2] }] },
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        0
      ]
    },
    "data": { "items": [1, 2, 3] },
    "result": 12
  },
  {
    "description": "Fused: sum of map with field-extract body",
    "rule": {
      "reduce": [
        { "map": [{ "var": "items" }, { "var": "value" }] },
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        0
      ]
    },
    "data": { "items": [{ "value": 5 }, { "value": 7 }] },
    "result": 12
  },
  {
    "description": "Fused: line totals - sum of map with var*var body",
    "rule": {
      "reduce": [
        { "map": [{ "var": "items" }, { "*": [{ "var": "price" }, { "var": "qty" }] }] },
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        0
      ]
    },
    "data": { "items": [{ "price": 10, "qty": 2 }, { "price": 3, "qty": 5 }] },
    "result": 35
  },
  {
    "description": "Fused: float line totals with non-integral result",
    "rule": {
      "reduce": [
        { "map": [{ "var": "items" }, { "*": [{ "var": "price" }, { "var": "qty" }] }] },
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        0.25
      ]
    },
    "data": { "items": [{ "price": 2.5, "qty": 3 }, { "price": 1.25, "qty": 2 }] },
    "result": 10.25
  },
  {
    "description": "Fused: mixed int and float items promote",
    "rule": {
      "reduce": [
        { "map": [{ "var": "items" }, { "var": "v" }] },
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        0
      ]
    },
    "data": { "items": [{ "v": 2 }, { "v": 0.5 }] },
    "result": 2.5
  },
  {
    "description": "Fused: subtract fold over mapped values honors operand order",
    "rule": {
      "reduce": [
        { "map": [{ "var": "items" }, { "*": [{ "var": "" }, 2] }] },
        { "-": [{ "var": "current" }, { "var": "accumulator" }] },
        0
      ]
    },
    "data": { "items": [5, 2] },
    "result": -6
  },
  {
    "description": "Fusion bails: numeric strings fall back to general coercion",
    "rule": {
      "reduce": [
        { "map": [{ "var": "items" }, { "var": "v" }] },
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        0
      ]
    },
    "data": { "items": [{ "v": "4" }, { "v": "6" }] },
    "result": 10
  },
  {
    "description": "Fusion bails: nulls in mapped input fall back to general coercion",
    "rule": {
      "reduce": [
        { "map": [{ "var": "items" }, { "*": [{ "var": "" }, 2] }] },
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        0
      ]
    },
    "data": { "items": [1, null, 3] },
    "result": 8
  },
  {
    "description": "Fused: empty mapped input returns the initial value",
    "rule": {
      "reduce": [
        { "map": [{ "var": "items" }, { "*": [{ "var": "" }, 2] }] },
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        42
      ]
    },
    "data": { "items": [] },
    "result": 42
  },
  {
    "description": "Fusion bails: object (Bridge) input to the map",
    "rule": {
      "reduce": [
        { "map": [{ "var": "obj" }, { "var": "v" }] },
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        0
      ]
    },
    "data": { "obj": { "a": { "v": 1 }, "b": { "v": 2 } } },
    "result": 3
  },
  {
    "description": "Fused: i64 overflow promotes to float (map overflows, fold stays f64)",
    "rule": {
      "reduce": [
        { "map": [{ "var": "items" }, { "*": [{ "var": "" }, 2] }] },
        { "+": [{ "var": "accumulator" }, { "var": "current" }] },
        0
      ]
    },
    "data": { "items": [4611686018427387904, 4611686018427387904, 1] },
    "result": 1.8446744073709552e19
  }
]