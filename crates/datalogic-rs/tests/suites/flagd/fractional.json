[
    "# fractional — mirrors flagd's canonical Go conformance suite",
    "# Source: https://github.com/open-feature/flagd/blob/main/core/pkg/evaluator/fractional_test.go",
    "# Algorithm: bucket = (murmurhash3_x86_32(key) as u64 * total_weight as u64) >> 32",
    "#           variant = first bucket where cumulative_weight > bucket",

    "## TestFractionalEvaluation — `headerColor` flag, key = flagKey + email, 25/25/25/25 red/blue/green/yellow",
    {
        "description": "rachel@faas.com → blue",
        "rule": {
            "if": [
                { "in": ["@faas.com", { "var": ["email"] }] },
                {
                    "fractional": [
                        { "cat": [{ "var": "$flagd.flagKey" }, { "var": "email" }] },
                        ["red", 25], ["blue", 25], ["green", 25], ["yellow", 25]
                    ]
                },
                null
            ]
        },
        "data": { "email": "rachel@faas.com", "$flagd": { "flagKey": "headerColor" } },
        "result": "blue"
    },
    {
        "description": "monica@faas.com → yellow",
        "rule": {
            "if": [
                { "in": ["@faas.com", { "var": ["email"] }] },
                {
                    "fractional": [
                        { "cat": [{ "var": "$flagd.flagKey" }, { "var": "email" }] },
                        ["red", 25], ["blue", 25], ["green", 25], ["yellow", 25]
                    ]
                },
                null
            ]
        },
        "data": { "email": "monica@faas.com", "$flagd": { "flagKey": "headerColor" } },
        "result": "yellow"
    },
    {
        "description": "joey@faas.com → red",
        "rule": {
            "if": [
                { "in": ["@faas.com", { "var": ["email"] }] },
                {
                    "fractional": [
                        { "cat": [{ "var": "$flagd.flagKey" }, { "var": "email" }] },
                        ["red", 25], ["blue", 25], ["green", 25], ["yellow", 25]
                    ]
                },
                null
            ]
        },
        "data": { "email": "joey@faas.com", "$flagd": { "flagKey": "headerColor" } },
        "result": "red"
    },
    {
        "description": "ross@faas.com → blue",
        "rule": {
            "if": [
                { "in": ["@faas.com", { "var": ["email"] }] },
                {
                    "fractional": [
                        { "cat": [{ "var": "$flagd.flagKey" }, { "var": "email" }] },
                        ["red", 25], ["blue", 25], ["green", 25], ["yellow", 25]
                    ]
                },
                null
            ]
        },
        "data": { "email": "ross@faas.com", "$flagd": { "flagKey": "headerColor" } },
        "result": "blue"
    },

    "## customSeededHeaderColor — `cat`'d static seed 'my-seed' + email",
    {
        "description": "rachel@faas.com with custom seed → green",
        "rule": {
            "fractional": [
                { "cat": ["my-seed", { "var": "email" }] },
                ["red", 25], ["blue", 25], ["green", 25], ["yellow", 25]
            ]
        },
        "data": { "email": "rachel@faas.com" },
        "result": "green"
    },
    {
        "description": "monica@faas.com with custom seed → red",
        "rule": {
            "fractional": [
                { "cat": ["my-seed", { "var": "email" }] },
                ["red", 25], ["blue", 25], ["green", 25], ["yellow", 25]
            ]
        },
        "data": { "email": "monica@faas.com" },
        "result": "red"
    },
    {
        "description": "joey@faas.com with custom seed → blue",
        "rule": {
            "fractional": [
                { "cat": ["my-seed", { "var": "email" }] },
                ["red", 25], ["blue", 25], ["green", 25], ["yellow", 25]
            ]
        },
        "data": { "email": "joey@faas.com" },
        "result": "blue"
    },
    {
        "description": "ross@faas.com with custom seed → green",
        "rule": {
            "fractional": [
                { "cat": ["my-seed", { "var": "email" }] },
                ["red", 25], ["blue", 25], ["green", 25], ["yellow", 25]
            ]
        },
        "data": { "email": "ross@faas.com" },
        "result": "green"
    },

    "## footerColor — bucket-by `var email` only (no flagKey concat)",
    {
        "description": "ross@faas.com with email-only key → red",
        "rule": {
            "fractional": [
                { "var": "email" },
                ["red", 25], ["blue", 25], ["green", 25], ["yellow", 25]
            ]
        },
        "data": { "email": "ross@faas.com" },
        "result": "red"
    },

    "## non-even split 50/25/25 with literal-string key 'email'",
    {
        "description": "literal 'email' string seed → green (50/25/25 red/blue/green)",
        "rule": {
            "fractional": ["email", ["red", 50], ["blue", 25], ["green", 25]]
        },
        "data": { "email": "test4@faas.com" },
        "result": "green"
    },

    "## Implicit-key form — flagKey + targetingKey",
    {
        "description": "implicit (headerColor + foo@foo.com) 50/50 blue/green → green",
        "rule": {
            "fractional": [["blue", 50], ["green", 50]]
        },
        "data": { "targetingKey": "foo@foo.com", "$flagd": { "flagKey": "headerColor" } },
        "result": "green"
    },
    {
        "description": "implicit picks up targetingKey even when args[0] is var with missing field",
        "rule": {
            "fractional": [{ "var": "email" }, ["red", 50], ["blue", 50]]
        },
        "data": { "targetingKey": "foo@foo.com", "$flagd": { "flagKey": "headerColor" } },
        "result": "blue"
    },

    "## Missing/empty/null targetingKey in implicit form → null (caller falls back to default)",
    {
        "description": "missing targetingKey → null",
        "rule": { "fractional": [["blue", 50], ["green", 50]] },
        "data": { "$flagd": { "flagKey": "headerColor" } },
        "result": null
    },
    {
        "description": "null targetingKey → null",
        "rule": { "fractional": [["blue", 50], ["green", 50]] },
        "data": { "targetingKey": null, "$flagd": { "flagKey": "headerColor" } },
        "result": null
    },
    {
        "description": "empty targetingKey → null",
        "rule": { "fractional": [["blue", 50], ["green", 50]] },
        "data": { "targetingKey": "", "$flagd": { "flagKey": "headerColor" } },
        "result": null
    },
    {
        "description": "no email and no targetingKey → null",
        "rule": {
            "fractional": [
                { "var": "email" },
                ["red", 25], ["blue", 25], ["green", 25], ["yellow", 25]
            ]
        },
        "data": { "$flagd": { "flagKey": "headerColor" } },
        "result": null
    },

    "## Weight defaults and edge cases",
    {
        "description": "missing-weight entries default to 1 each → foo@foo.com lands on blue",
        "rule": {
            "fractional": [{ "var": "email" }, ["red"], ["blue"]]
        },
        "data": { "email": "foo@foo.com" },
        "result": "blue"
    },
    {
        "description": "weights [25,25] (sum=50) → foo@foo.com lands on blue",
        "rule": {
            "fractional": [{ "var": "email" }, ["red", 25], ["blue", 25]]
        },
        "data": { "email": "foo@foo.com" },
        "result": "blue"
    },
    {
        "description": "single entry with explicit weight returns that variant",
        "rule": { "fractional": [["blue", 1]] },
        "data": { "targetingKey": "any-user", "$flagd": { "flagKey": "headerColor" } },
        "result": "blue"
    },
    {
        "description": "single entry with explicit bucket-by always returns the sole variant",
        "rule": {
            "fractional": [{ "var": "email" }, ["green", 100]]
        },
        "data": { "email": "any@user.com" },
        "result": "green"
    },
    {
        "description": "single entry without weight returns that variant",
        "rule": { "fractional": [["yellow"]] },
        "data": { "targetingKey": "any-user", "$flagd": { "flagKey": "headerColor" } },
        "result": "yellow"
    },

    "## Determinism — same input, same variant on every call",
    {
        "description": "rachel@faas.com pinned (call 1/2)",
        "rule": {
            "fractional": [
                { "cat": [{ "var": "$flagd.flagKey" }, { "var": "email" }] },
                ["red", 25], ["blue", 25], ["green", 25], ["yellow", 25]
            ]
        },
        "data": { "email": "rachel@faas.com", "$flagd": { "flagKey": "headerColor" } },
        "result": "blue"
    },
    {
        "description": "rachel@faas.com pinned (call 2/2)",
        "rule": {
            "fractional": [
                { "cat": [{ "var": "$flagd.flagKey" }, { "var": "email" }] },
                ["red", 25], ["blue", 25], ["green", 25], ["yellow", 25]
            ]
        },
        "data": { "email": "rachel@faas.com", "$flagd": { "flagKey": "headerColor" } },
        "result": "blue"
    },

    "## Edge cases not in the Go suite but worth pinning",
    {
        "description": "no args → null",
        "rule": { "fractional": [] },
        "data": { "targetingKey": "any" },
        "result": null
    },
    {
        "description": "explicit key but no buckets → null",
        "rule": { "fractional": ["alice"] },
        "data": {},
        "result": null
    },

    "## flagd-testbed v3.1.0–v3.5.0 conformance (PR open-feature/go-sdk-contrib#866)",
    "## Source: https://github.com/open-feature/flagd-testbed — flags/custom-ops.json + flags/edge-case-flags.json",

    "### fractional-single-entry-flag — single bucket always resolves to that variant",
    {
        "description": "single-entry-flag: any targetingKey → 'single'",
        "rule": { "fractional": [["single", 1]] },
        "data": { "targetingKey": "some-targeting-key", "$flagd": { "flagKey": "fractional-single-entry-flag" } },
        "result": "single"
    },

    "### fractional-hash-edge-flag — bucket-boundary pins ({\"var\":\"targetingKey\"}, 50/50 lower/upper)",
    {
        "description": "hash-edge ejOoVL → lower",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                ["lower", 50], ["upper", 50]
            ]
        },
        "data": { "targetingKey": "ejOoVL", "$flagd": { "flagKey": "fractional-hash-edge-flag" } },
        "result": "lower"
    },
    {
        "description": "hash-edge bY9fO- → lower",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                ["lower", 50], ["upper", 50]
            ]
        },
        "data": { "targetingKey": "bY9fO-", "$flagd": { "flagKey": "fractional-hash-edge-flag" } },
        "result": "lower"
    },
    {
        "description": "hash-edge SI7p- → lower",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                ["lower", 50], ["upper", 50]
            ]
        },
        "data": { "targetingKey": "SI7p-", "$flagd": { "flagKey": "fractional-hash-edge-flag" } },
        "result": "lower"
    },
    {
        "description": "hash-edge 6LvT0 → upper",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                ["lower", 50], ["upper", 50]
            ]
        },
        "data": { "targetingKey": "6LvT0", "$flagd": { "flagKey": "fractional-hash-edge-flag" } },
        "result": "upper"
    },
    {
        "description": "hash-edge ceQdGm → upper",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                ["lower", 50], ["upper", 50]
            ]
        },
        "data": { "targetingKey": "ceQdGm", "$flagd": { "flagKey": "fractional-hash-edge-flag" } },
        "result": "upper"
    },

    "### fractional-nested-if-flag — nested `if` resolves the variant name in bucket0 (jon@company.com → bucket0, user1 → bucket1)",
    {
        "description": "nested-if jon@company.com + tier=premium → 'premium' (bucket0, if-true)",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                [
                    { "if": [{ "==": [{ "var": "tier" }, "premium"] }, "premium", "standard"] },
                    50
                ],
                ["standard", 50]
            ]
        },
        "data": { "targetingKey": "jon@company.com", "tier": "premium", "$flagd": { "flagKey": "fractional-nested-if-flag" } },
        "result": "premium"
    },
    {
        "description": "nested-if jon@company.com + tier=basic → 'standard' (bucket0, if-false)",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                [
                    { "if": [{ "==": [{ "var": "tier" }, "premium"] }, "premium", "standard"] },
                    50
                ],
                ["standard", 50]
            ]
        },
        "data": { "targetingKey": "jon@company.com", "tier": "basic", "$flagd": { "flagKey": "fractional-nested-if-flag" } },
        "result": "standard"
    },
    {
        "description": "nested-if user1 + tier=premium → 'standard' (bucket1, regardless of nested if)",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                [
                    { "if": [{ "==": [{ "var": "tier" }, "premium"] }, "premium", "standard"] },
                    50
                ],
                ["standard", 50]
            ]
        },
        "data": { "targetingKey": "user1", "tier": "premium", "$flagd": { "flagKey": "fractional-nested-if-flag" } },
        "result": "standard"
    },
    {
        "description": "nested-if user1 + tier=basic → 'standard' (bucket1)",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                [
                    { "if": [{ "==": [{ "var": "tier" }, "premium"] }, "premium", "standard"] },
                    50
                ],
                ["standard", 50]
            ]
        },
        "data": { "targetingKey": "user1", "tier": "basic", "$flagd": { "flagKey": "fractional-nested-if-flag" } },
        "result": "standard"
    },

    "### fractional-nested-var-flag — nested `{var: color}` resolves the variant name in bucket0",
    "###   Operator-level expectation: pass through whatever color resolves to (testbed-level falls back to defaultVariant when color is not a registered variant).",
    {
        "description": "nested-var jon@company.com + color=red → 'red' (bucket0)",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                [{ "var": "color" }, 50],
                ["blue", 50]
            ]
        },
        "data": { "targetingKey": "jon@company.com", "color": "red", "$flagd": { "flagKey": "fractional-nested-var-flag" } },
        "result": "red"
    },
    {
        "description": "nested-var jon@company.com + color=green → 'green' (bucket0)",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                [{ "var": "color" }, 50],
                ["blue", 50]
            ]
        },
        "data": { "targetingKey": "jon@company.com", "color": "green", "$flagd": { "flagKey": "fractional-nested-var-flag" } },
        "result": "green"
    },
    {
        "description": "nested-var user1 + color=red → 'blue' (bucket1, regardless of color)",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                [{ "var": "color" }, 50],
                ["blue", 50]
            ]
        },
        "data": { "targetingKey": "user1", "color": "red", "$flagd": { "flagKey": "fractional-nested-var-flag" } },
        "result": "blue"
    },
    {
        "description": "nested-var jon@company.com + color=yellow → operator returns 'yellow' (testbed flag→'fallback' via defaultVariant)",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                [{ "var": "color" }, 50],
                ["blue", 50]
            ]
        },
        "data": { "targetingKey": "jon@company.com", "color": "yellow", "$flagd": { "flagKey": "fractional-nested-var-flag" } },
        "result": "yellow"
    },
    {
        "description": "nested-var jon@company.com + color=\"\" → operator returns '' (testbed flag→'fallback' via defaultVariant)",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                [{ "var": "color" }, 50],
                ["blue", 50]
            ]
        },
        "data": { "targetingKey": "jon@company.com", "color": "", "$flagd": { "flagKey": "fractional-nested-var-flag" } },
        "result": ""
    },

    "### fractional-nested-weight-flag — nested `if` resolves the *weight* in bucket0 (tier=premium → weight 100, basic → 0)",
    {
        "description": "nested-weight jon@company.com + premium → 'red' (weights 100/10, bucket0)",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                [
                    "red",
                    { "if": [{ "==": [{ "var": "tier" }, "premium"] }, 100, 0] }
                ],
                ["blue", 10]
            ]
        },
        "data": { "targetingKey": "jon@company.com", "tier": "premium", "$flagd": { "flagKey": "fractional-nested-weight-flag" } },
        "result": "red"
    },
    {
        "description": "nested-weight jon@company.com + basic → 'blue' (weights 0/10, red weight collapses)",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                [
                    "red",
                    { "if": [{ "==": [{ "var": "tier" }, "premium"] }, 100, 0] }
                ],
                ["blue", 10]
            ]
        },
        "data": { "targetingKey": "jon@company.com", "tier": "basic", "$flagd": { "flagKey": "fractional-nested-weight-flag" } },
        "result": "blue"
    },
    {
        "description": "nested-weight user1 + premium → 'red'",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                [
                    "red",
                    { "if": [{ "==": [{ "var": "tier" }, "premium"] }, 100, 0] }
                ],
                ["blue", 10]
            ]
        },
        "data": { "targetingKey": "user1", "tier": "premium", "$flagd": { "flagKey": "fractional-nested-weight-flag" } },
        "result": "red"
    },
    {
        "description": "nested-weight user1 + basic → 'blue'",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                [
                    "red",
                    { "if": [{ "==": [{ "var": "tier" }, "premium"] }, 100, 0] }
                ],
                ["blue", 10]
            ]
        },
        "data": { "targetingKey": "user1", "tier": "basic", "$flagd": { "flagKey": "fractional-nested-weight-flag" } },
        "result": "blue"
    },

    "### fractional-null-bucket-key-flag — bucket key var missing → operator returns null (testbed flag→'fallback' via defaultVariant)",
    {
        "description": "null-bucket-key: {var:missing_key} → null, no targetingKey for implicit fallback → null",
        "rule": {
            "fractional": [
                { "var": "missing_key" },
                ["one", 50],
                ["two", 50]
            ]
        },
        "data": { "$flagd": { "flagKey": "fractional-null-bucket-key-flag" } },
        "result": null
    },

    "### fractional-zero-weights-flag — all-zero weights → operator returns null (testbed flag→'fallback' via defaultVariant)",
    {
        "description": "zero-weights any-user → null (total weight 0)",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                ["one", 0],
                ["two", 0]
            ]
        },
        "data": { "targetingKey": "any-user", "$flagd": { "flagKey": "fractional-zero-weights-flag" } },
        "result": null
    },

    "### fractional-negative-weight-flag — negative weight clamped to 0; survivor takes 100% of bucket space",
    {
        "description": "negative-weight any-user → 'two' (one clamped 0, two=100)",
        "rule": {
            "fractional": [
                { "var": "targetingKey" },
                ["one", -50],
                ["two", 100]
            ]
        },
        "data": { "targetingKey": "any-user", "$flagd": { "flagKey": "fractional-negative-weight-flag" } },
        "result": "two"
    }
]
