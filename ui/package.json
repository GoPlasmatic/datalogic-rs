{
  "name": "@goplasmatic/datalogic-ui",
  "private": false,
  "version": "5.1.0",
  "type": "module",
  "description": "React rule builder, visual debugger, and editor for JSONLogic (json-logic) — flow-diagram view and live execution tracing, powered by the datalogic-rs WASM engine.",
  "keywords": [
    "jsonlogic",
    "json-logic",
    "rules-engine",
    "rule-builder",
    "rule-editor",
    "visual-debugger",
    "logic-editor",
    "business-rules",
    "react",
    "react-component",
    "flow-diagram",
    "debugger"
  ],
  "homepage": "https://goplasmatic.github.io/datalogic-rs/playground/",
  "repository": {
    "type": "git",
    "url": "https://github.com/GoPlasmatic/datalogic-rs",
    "directory": "ui"
  },
  "author": "Plasmatic",
  "license": "Apache-2.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/lib.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/lib.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist/index.js",
    "dist/index.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/styles.css",
    "dist/datalogic_wasm-*.js",
    "dist/datalogic_wasm-*.cjs",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:embed": "vite build --config vite.embed.config.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib",
    "predev": "npm run sync-wasm",
    "prebuild": "npm run sync-wasm",
    "prebuild:lib": "npm run sync-wasm",
    "prebuild:embed": "npm run sync-wasm",
    "sync-wasm": "rm -rf vendor/datalogic && mkdir -p vendor && cp -R ../bindings/wasm/pkg vendor/datalogic"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@goplasmatic/datalogic-wasm": "5.1.0",
    "@msgpack/msgpack": "^3.1.3",
    "fflate": "^0.8.3",
    "lucide-react": "^1.23.0",
    "uuid": "^14.0.1"
  },
  "peerDependencies": {
    "@xyflow/react": "^12.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@xyflow/react": "^12.11.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-wasm": "^3.6.0"
  }
}
