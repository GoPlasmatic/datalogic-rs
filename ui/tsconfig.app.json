{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /* Path aliases */
    "paths": {
      "@/*": ["./src/*"],
      "@logic-editor/*": ["./src/components/logic-editor/*"],
      // Mirror the vite.config.ts alias so `tsc` resolves the WASM dep to
      // the vendored copy (kept fresh by the `sync-wasm` prebuild) instead
      // of the node_modules link. Keeps `tsc -b` and `vite build` in sync.
      "@goplasmatic/datalogic-wasm": ["./vendor/datalogic"]
    }
  },
  "include": ["src"]
}
